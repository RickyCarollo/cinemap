{
  "rewrites": [
    {
      "source": "/scena/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/directors",
      "destination": "/index.html"
    },
    {
      "source": "/map",
      "destination": "/index.html"
    },
    {
      "source": "/percorsi",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "X-Frame-Options", "value": "DENY"}
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {"key": "Content-Type", "value": "application/xml"}
      ]
    }
  ]
}
